# Salin file ini menjadi .env.local lalu isi nilainya

# ============================================
# API
# ============================================

# Base URL API backend
# Contoh: https://api.itfest-filkom.com/api/v1
NEXT_PUBLIC_API_BASE_URL=

# ============================================
# Keamanan / Auth
# ============================================

# Key untuk enkripsi token di cookie (diakses client-side)
# Dipakai di: src/api/core/core.ts
NEXT_PUBLIC_ENCRYPTION_KEY=

# Key untuk dekripsi token (diakses server-side saja)
# Dipakai di: src/proxy.ts
ENCRYPTION_KEY=

# Secret untuk verifikasi JWT token (diakses server-side saja)
# Dipakai di: src/proxy.ts
JWT_SECRET=